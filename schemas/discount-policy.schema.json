{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runcost.dev/schemas/discount-policy.schema.json",
  "title": "DiscountPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "adjustment"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string" },
        "surface": { "type": "string" },
        "model": { "type": "string" },
        "service_tier": { "type": "string" },
        "region": { "type": "string" },
        "components": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exclude_components": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "effective": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from": { "type": ["string", "null"], "format": "date" },
        "to": { "type": ["string", "null"], "format": "date" }
      }
    },
    "adjustment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["multiplier", "percentage_discount", "percentage_markup"]
        },
        "value": {
          "type": "string",
          "pattern": "^-?[0-9]+(\\.[0-9]+)?$"
        }
      }
    },
    "precedence": {
      "type": "integer",
      "minimum": 0,
      "default": 100
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
