{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runcost.dev/schemas/public-api-registry.schema.json",
  "title": "RunCost Public API Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "updated_at", "description", "capabilities"],
  "properties": {
    "schema_version": { "const": "0.1" },
    "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "description": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability" }
    }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "status", "evidence", "languages"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "category": {
          "type": "string",
          "enum": ["core", "provider_extractor", "framework_adapter", "source_adapter", "type_contract", "language_specific"]
        },
        "status": {
          "type": "string",
          "enum": ["polyglot", "language_specific", "partial"]
        },
        "notes": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "languages": {
          "type": "object",
          "additionalProperties": false,
          "required": ["python", "javascript", "go"],
          "properties": {
            "python": { "$ref": "#/$defs/languageApi" },
            "javascript": { "$ref": "#/$defs/languageApi" },
            "go": { "$ref": "#/$defs/languageApi" }
          }
        }
      }
    },
    "languageApi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "types"],
      "properties": {
        "runtime": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "types": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
