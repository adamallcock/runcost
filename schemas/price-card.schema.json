{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runcost.dev/schemas/price-card.schema.json",
  "title": "PriceCard",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "provider", "model", "components", "source"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "surface": {
      "type": "string"
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "service_tier": {
      "type": "string",
      "default": "standard"
    },
    "region": {
      "type": "string"
    },
    "effective": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from": { "type": ["string", "null"], "format": "date" },
        "to": { "type": ["string", "null"], "format": "date" }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/price_component" }
    },
    "source": { "$ref": "#/$defs/source" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "price_component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["usage_component", "unit", "price"],
      "properties": {
        "usage_component": {
          "type": "string"
        },
        "unit": {
          "type": "string",
          "enum": ["token", "request", "call", "session", "search", "file", "image", "video", "audio", "second", "hour", "gb_day", "usd", "custom"]
        },
        "price": {
          "type": "object",
          "additionalProperties": false,
          "required": ["amount", "currency", "per"],
          "properties": {
            "amount": {
              "type": "string",
              "pattern": "^-?[0-9]+(\\.[0-9]+)?$"
            },
            "currency": {
              "type": "string",
              "minLength": 3,
              "maxLength": 3
            },
            "per": {
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)?$"
            }
          }
        },
        "discount_eligible": {
          "type": "boolean",
          "default": true
        },
        "conditions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min_total_input_tokens": {
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)?$"
            },
            "max_total_input_tokens": {
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)?$"
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "version": { "type": "string" },
        "license": { "type": "string" }
      }
    }
  }
}
