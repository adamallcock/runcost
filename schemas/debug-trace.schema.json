{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runcost.dev/schemas/debug-trace.schema.json",
  "title": "DebugTrace",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "decisions", "summary"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/debug_decision" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["priced_components", "unpriced_components", "warnings", "applied_discounts"],
      "properties": {
        "priced_components": { "type": "integer", "minimum": 0 },
        "unpriced_components": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "applied_discounts": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "debug_decision": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "price_card_candidates",
            "price_component_match",
            "model_alias_resolution",
            "discount_application",
            "warning"
          ]
        },
        "component": { "type": "string" },
        "model": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "resolution": { "type": "string" },
        "price_card_id": { "type": "string" },
        "selected_price_card_id": { "type": "string" },
        "selected_source": { "type": "string" },
        "candidate_price_card_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_priority": {
          "type": "array",
          "items": { "type": "string" }
        },
        "policy_id": { "type": "string" },
        "amount": { "type": "string" },
        "warning_code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
