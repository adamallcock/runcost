{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runcost.dev/schemas/project-completion-gates.schema.json",
  "title": "RunCost Project Completion Gates",
  "type": "object",
  "required": [
    "schema_version",
    "updated_at",
    "status_scale",
    "gates"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    },
    "status_scale": {
      "type": "object",
      "required": [
        "satisfied",
        "partial",
        "pending_external_evidence",
        "deferred_by_user",
        "not_started"
      ],
      "properties": {
        "satisfied": {
          "type": "string",
          "minLength": 1
        },
        "partial": {
          "type": "string",
          "minLength": 1
        },
        "pending_external_evidence": {
          "type": "string",
          "minLength": 1
        },
        "deferred_by_user": {
          "type": "string",
          "minLength": 1
        },
        "not_started": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/gate"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "status": {
      "enum": [
        "satisfied",
        "partial",
        "pending_external_evidence",
        "deferred_by_user",
        "not_started"
      ]
    },
    "area": {
      "enum": [
        "milestone8",
        "milestone9",
        "public_beta",
        "polyglot",
        "provider_framework_breadth",
        "v1"
      ]
    },
    "requirement": {
      "enum": [
        "milestone8",
        "public_beta",
        "v1"
      ]
    },
    "evidence": {
      "type": "object",
      "required": [
        "kind",
        "proves"
      ],
      "properties": {
        "kind": {
          "enum": [
            "code",
            "docs",
            "fixture",
            "register",
            "report",
            "schema",
            "script",
            "workflow"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "proves": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "gate": {
      "type": "object",
      "required": [
        "id",
        "area",
        "requirement",
        "status",
        "required_for",
        "required_evidence",
        "current_evidence",
        "completion_check"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "area": {
          "$ref": "#/$defs/area"
        },
        "requirement": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "required_for": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/requirement"
          }
        },
        "required_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "current_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "completion_check": {
          "type": "string",
          "minLength": 1
        },
        "remaining_action": {
          "type": "string",
          "minLength": 1
        },
        "deferred_reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "const": "satisfied"
              }
            }
          },
          "then": {
            "properties": {
              "current_evidence": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "const": "deferred_by_user"
              }
            }
          },
          "then": {
            "required": [
              "deferred_reason",
              "remaining_action"
            ]
          }
        },
        {
          "if": {
            "required": [
              "status"
            ],
            "properties": {
              "status": {
                "enum": [
                  "partial",
                  "pending_external_evidence",
                  "not_started"
                ]
              }
            }
          },
          "then": {
            "required": [
              "remaining_action"
            ]
          }
        }
      ]
    }
  }
}
